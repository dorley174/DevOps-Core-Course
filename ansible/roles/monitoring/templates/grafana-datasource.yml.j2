apiVersion: 1

deleteDatasources:
  - name: {{ monitoring_loki_datasource_name }}
    orgId: 1
  - name: {{ monitoring_prometheus_datasource_name }}
    orgId: 1

prune: true

datasources:
  - name: {{ monitoring_loki_datasource_name }}
    uid: {{ monitoring_loki_datasource_uid }}
    type: loki
    access: proxy
    url: http://loki:3100
    isDefault: true
    editable: false
    jsonData:
      maxLines: 1000
      timeout: 60

  - name: {{ monitoring_prometheus_datasource_name }}
    uid: {{ monitoring_prometheus_datasource_uid }}
    type: prometheus
    access: proxy
    url: http://prometheus:9090
    isDefault: false
    editable: false
    jsonData:
      httpMethod: POST
      prometheusType: Prometheus
      timeInterval: {{ monitoring_prometheus_scrape_interval }}
