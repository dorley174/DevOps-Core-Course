version: '{{ docker_compose_version }}'

services:
  {{ app_name }}:
    image: {{ docker_image }}:{{ docker_tag }}
    container_name: {{ app_name }}
    ports:
      - "{{ app_port }}:{{ app_internal_port }}"
    environment:
      # Defaults to make the provided Flask app listen on the expected port.
      HOST: "0.0.0.0"
      PORT: "{{ app_internal_port }}"
{%- if app_env is defined and app_env | length > 0 %}
{%- for key, value in app_env.items() %}
      {{ key }}: {{ value | quote }}
{%- endfor %}
{%- endif %}
{%- if app_secret_key is defined %}
      APP_SECRET_KEY: {{ app_secret_key | quote }}
{%- endif %}
    restart: unless-stopped
    networks:
      - {{ app_name }}_net

networks:
  {{ app_name }}_net:
    driver: bridge
